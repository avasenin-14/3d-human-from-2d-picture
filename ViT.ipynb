        "# --- Visualization Helper ---\n",
        "def cam_to_translation(cam, focal_length=5000., img_res=224):\n",
        "    \"\"\"Convert weak perspective camera (s, tx, ty) to 3D translation (tx, ty, tz).\"\"\"\n",
        "    s, tx, ty = cam\n",
        "    tz = 2 * focal_length / (img_res * s + 1e-9)\n",
        "    return np.array([tx, ty, tz])\n",
